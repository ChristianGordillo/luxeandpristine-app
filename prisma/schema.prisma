// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCama {
  KING
  QUEEN
  TWIN
  SOFA_CAMA
}

model LPUnidad {
  id           Int    @id @default(autoincrement())
  nombre       String
  habitaciones Int
  banos        Float

  camas        Int?
  camasDetalle String?

  precio Float

  activo Boolean @default(true)

  clienteId  Int
  edificioId Int

  cliente  LPCliente  @relation(fields: [clienteId], references: [id])
  edificio LPEdificio @relation(fields: [edificioId], references: [id])

  trabajos LPTrabajoDiario[]

  programaciones LPProgramacionTrabajo[]

  ropaPendiente LPRopaPendiente[]
  ropaManchada  LPRopaManchada[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LPCliente {
  id       Int     @id @default(autoincrement())
  nombre   String  @unique
  tipo     String?
  telefono String?
  email    String?
  activo   Boolean @default(true)

  usaSaldoAnticipado  Boolean   @default(false)
  fechaInicioSaldo    DateTime?

  unidades               LPUnidad[]
  movimientosFinancieros LPMovimientoCliente[]
  ciclosFinancieros      LPCicloCliente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LPEdificio {
  id        Int     @id @default(autoincrement())
  nombre    String  @unique
  direccion String?
  ciudad    String? @default("Miami")
  activo    Boolean @default(true)

  unidades LPUnidad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LPTrabajoTipo {
  LIMPIEZA_INICIAL
  LIMPIEZA
  EXTRA
  REPASO_LIMPIEZA
}

model LPTrabajoDiario {
  id Int @id @default(autoincrement())

  fecha DateTime
  dia   String

  tipo   LPTrabajoTipo @default(LIMPIEZA)
  precio Float
  notas  String?

  incidenciaAbierta     Boolean   @default(false)
  fechaCierreIncidencia DateTime?

  unidadId Int?
  unidad   LPUnidad? @relation(fields: [unidadId], references: [id])

  unidadManual String?

  asignaciones   LPAsignacionTrabajo[]
  checkIn        Boolean               @default(false)
  revisionEstado LPRevisionEstado?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LPPagoPeriodo {
  id Int @id @default(autoincrement())

  fechaInicio DateTime
  fechaFin    DateTime
  pagado      Boolean  @default(false)
  notas       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fechaInicio, fechaFin])
}

model LPCleaner {
  id Int @id @default(autoincrement())

  nombre     String
  telefono   String?
  paisOrigen String?

  activo Boolean @default(true)

  asignaciones LPAsignacionTrabajo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LPRolOperativo {
  CLEANER
  VOLANTE
}

model LPAsignacionTrabajo {
  id Int @id @default(autoincrement())

  trabajoId Int
  trabajo   LPTrabajoDiario @relation(fields: [trabajoId], references: [id])

  cleanerId Int
  cleaner   LPCleaner @relation(fields: [cleanerId], references: [id])

  rol LPRolOperativo

  valorPago Float

  metodoPago String?

  notas String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LPCostoOperativoDiario {
  id Int @id @default(autoincrement())

  fecha    DateTime
  concepto String
  valor    Float
  notas    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LPProgramacionEstado {
  PROGRAMADO
  CANCELADO
}

model LPProgramacionTrabajo {
  id Int @id @default(autoincrement())

  fecha DateTime
  dia   String

  tipo LPTrabajoTipo @default(LIMPIEZA)

  unidadId Int?
  unidad   LPUnidad? @relation(fields: [unidadId], references: [id])

  unidadManual String?

  estado  LPProgramacionEstado @default(PROGRAMADO)
  checkIn Boolean              @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LPRopaPendiente {
  id Int @id @default(autoincrement())

  unidadId Int
  unidad   LPUnidad @relation(fields: [unidadId], references: [id])

  activo Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cerradoAt DateTime?
}

enum LPRevisionEstado {
  SIN_NOVEDADES
  NOVEDAD_REGISTRADA
  INCIDENCIA_ABIERTA
}

model LPProveedorCompra {
  id Int @id @default(autoincrement())

  nombre String  @unique
  activo Boolean @default(true)

  compras LPCompra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
}

model LPProductoCompra {
  id Int @id @default(autoincrement())

  nombre            String
  nombreNormalizado String @unique

  marca        String?
  presentacion String?

  activo Boolean @default(true)

  items LPCompraItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nombre])
  @@index([marca])
  @@index([activo])
}

enum LPGastoCategoria {
  GASOLINA
  REPUESTOS_CARRO
  INSUMOS
  TAXES
  NOMINA
  OTROS
}

model LPCompra {
  id Int @id @default(autoincrement())

  fecha     DateTime
  categoria LPGastoCategoria

  proveedorId Int
  proveedor   LPProveedorCompra @relation(fields: [proveedorId], references: [id])

  subtotal Float
  taxes    Float
  total    Float

  items LPCompraItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([categoria])
  @@index([proveedorId])
}

model LPCompraItem {
  id Int @id @default(autoincrement())

  compraId Int
  compra   LPCompra @relation(fields: [compraId], references: [id], onDelete: Cascade)

  productoId Int?
  producto   LPProductoCompra? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  // Conserva el nombre exacto registrado en la compra.
  nombre String

  cantidad Float @default(1)

  // Total de la línea antes de taxes.
  precioBase Float

  // Parte de los taxes asignada a este producto.
  taxAsignado Float

  // Total de la línea con taxes incluidos.
  precioFinal Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([compraId])
  @@index([productoId])
  @@index([nombre])
}

model LPRopaManchada {
  id       Int      @id @default(autoincrement())
  unidadId Int
  unidad   LPUnidad @relation(fields: [unidadId], references: [id])

  item     String
  cantidad Int     @default(1)
  cambiada Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  fechaCambio DateTime?
}

enum LPMovimientoClienteTipo {
  ABONO
  AJUSTE_CREDITO
  AJUSTE_DEBITO
  DEVOLUCION
}

model LPMovimientoCliente {
  id         Int                     @id @default(autoincrement())
  clienteId  Int
  fecha      DateTime
  tipo       LPMovimientoClienteTipo
  valor      Decimal                 @db.Decimal(10, 2)
  concepto   String
  referencia String?
  notas      String?

  cliente LPCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  aplicacionesPago LPAplicacionPagoCliente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId])
  @@index([fecha])
  @@index([clienteId, fecha])
  @@index([tipo])
}

enum LPCicloClienteTipo {
  DIARIO
  SEMANAL
  QUINCENAL
  MENSUAL
  PERSONALIZADO
}

model LPCicloCliente {
  id Int @id @default(autoincrement())

  clienteId Int
  cliente   LPCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo LPCicloClienteTipo

  fechaInicio DateTime
  fechaFin    DateTime

  concepto String?
  notas    String?

  aplicacionesPago LPAplicacionPagoCliente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, fechaInicio, fechaFin])
  @@index([clienteId])
  @@index([fechaInicio])
  @@index([fechaFin])
  @@index([clienteId, fechaInicio, fechaFin])
}

model LPAplicacionPagoCliente {
  id Int @id @default(autoincrement())

  movimientoId Int
  movimiento   LPMovimientoCliente @relation(fields: [movimientoId], references: [id], onDelete: Cascade)

  cicloId Int
  ciclo   LPCicloCliente @relation(fields: [cicloId], references: [id], onDelete: Cascade)

  valorAplicado Decimal @db.Decimal(10, 2)

  notas String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movimientoId, cicloId])
  @@index([movimientoId])
  @@index([cicloId])
}
